# Φόρμα επικοινωνίας — αποστολή μέσω Resend (https://resend.com)
# Χωρίς RESEND_API_KEY: σε development το μήνυμα γράφεται στο console,
# σε production η φόρμα επιστρέφει 503 και παραπέμπει στο info@uplab.gr.
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@uplab.gr
# Το from πρέπει να ανήκει σε verified domain στο Resend (π.χ. website@uplab.gr)
CONTACT_FROM_EMAIL=Uplab Website <onboarding@resend.dev>
